{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve site on port 8080",
      "type": "shell",
      "command": "python3 -u -m http.server 8080 --bind 127.0.0.1",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "http-server",
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP"
        }
      }
    }
  ]
}
